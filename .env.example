# ==============================================================================
# RacingPlanner — environment variables
# Copy to .env (local dev) and fill in real values. NEVER commit .env.
# In production, set these in Render (backend) / Netlify (frontend) dashboards.
# ==============================================================================

# --- Core ---
# Comma-separated list of allowed frontend origins for CORS.
# Local dev: http://localhost:5173 (Vite default). Prod: your Netlify URL.
FRONTEND_ORIGIN=http://localhost:5173

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Database (Postgres) ---
# Local: docker-compose uses its own value. Override for Neon/Supabase/etc.
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://racing:racing@localhost:5432/racingplanner

# --- Session secret ---
# Signs the session cookie. 32+ random bytes, hex or base64.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-generate-a-real-secret-with-secrets.token_hex(32)

# --- Strava OAuth ---
# Create an app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match exactly what's registered in your Strava API app
STRAVA_REDIRECT_URI=http://localhost:8000/auth/callback

# Shared secret that Strava echoes back during webhook subscription setup.
# Optional — leave blank to disable the /api/webhooks/strava endpoint.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
# After setting, register the subscription with the CLI script:
#   python backend/scripts/manage_strava_subscription.py create \
#       --callback-url https://your-backend/api/webhooks/strava
STRAVA_WEBHOOK_VERIFY_TOKEN=

# --- Garmin (per-user credential encryption) ---
# Master key from which per-user Fernet keys are derived via HKDF.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GARMIN_MASTER_KEY=changeme-generate-a-real-master-key

# --- Admin bootstrap ---
# Your Strava athlete ID — the first login with this ID becomes the admin.
# Find yours at https://www.strava.com/athletes/<YOUR_ID> after login.
ADMIN_ATHLETE_ID=

# --- Error tracking (optional) ---
SENTRY_DSN=

# --- Frontend build-time (set in Netlify) ---
# VITE_API_BASE=https://racingplanner-api.onrender.com
